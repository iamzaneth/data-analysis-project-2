table mart_geolocation

	column year
		dataType: int64
		sourceColumn: year

	column month
		dataType: int64
		sourceColumn: month

	column month_name
		dataType: string
		sourceColumn: month_name

	column customer_state
		dataType: string
		sourceColumn: customer_state

	column customer_city
		dataType: string
		sourceColumn: customer_city

	column total_orders
		dataType: int64
		summarizeBy: sum
		sourceColumn: total_orders

	column total_customers
		dataType: int64
		summarizeBy: sum
		sourceColumn: total_customers

	column total_revenue
		dataType: decimal
		summarizeBy: sum
		sourceColumn: total_revenue

	column gross_merchandise_value
		dataType: decimal
		summarizeBy: sum
		sourceColumn: gross_merchandise_value

	column total_freight_value
		dataType: decimal
		summarizeBy: sum
		sourceColumn: total_freight_value

	column avg_order_value
		dataType: decimal
		summarizeBy: none
		sourceColumn: avg_order_value

	column delivered_orders
		dataType: int64
		summarizeBy: sum
		sourceColumn: delivered_orders

	column late_orders
		dataType: int64
		summarizeBy: sum
		sourceColumn: late_orders

	column late_rate_pct
		dataType: decimal
		summarizeBy: none
		sourceColumn: late_rate_pct

	column avg_delivery_days
		dataType: decimal
		summarizeBy: none
		sourceColumn: avg_delivery_days

	column avg_delay_days
		dataType: decimal
		summarizeBy: none
		sourceColumn: avg_delay_days

	column avg_review_score
		dataType: decimal
		summarizeBy: none
		sourceColumn: avg_review_score

	column low_review_rate_pct
		dataType: decimal
		summarizeBy: none
		sourceColumn: low_review_rate_pct

	column total_payment_value
		dataType: decimal
		summarizeBy: sum
		sourceColumn: total_payment_value

	column avg_payment_value
		dataType: decimal
		summarizeBy: none
		sourceColumn: avg_payment_value

	column period_start
		dataType: dateTime
		sourceColumn: period_start

	column year_month
		dataType: string
		sourceColumn: year_month

	partition mart_geolocation = m
		mode: import
		source =
				let
				    Source = PostgreSQL.Database(PgServer, PgDatabase),
				    Data = Source{[Schema = "mart", Item = "mart_geolocation"]}[Data],
				    Result = AddPeriodColumns(Data)
				in
				    Result

