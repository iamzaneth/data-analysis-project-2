model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["_Measures","mart_sales","mart_logistics","mart_customer_satisfaction","mart_seller_performance","mart_product_category","mart_payment","mart_geolocation"]

ref table _Measures
ref table mart_sales
ref table mart_logistics
ref table mart_customer_satisfaction
ref table mart_seller_performance
ref table mart_product_category
ref table mart_payment
ref table mart_geolocation

